{
  "expo": {
    "name": "jisho",
    "slug": "jisho",
    "version": "1.0.0",
    "scheme": "myapp",
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-sqlite",
      "expo-audio",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    },
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.jisho.loc",
      "supportsTablet": true,
      "infoPlist": {
        "SKPaymentTransactionObserver": true
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "app.jisho.loc"
    }
  }
}
