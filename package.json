{
  "name": "jisho",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "db:create": "tsx scripts/migrate.ts --create",
    "db:import": "tsx scripts/migrate.ts --import",
    "db:import:words": "tsx scripts/migrate.ts --import-words",
    "db:import:furigana": "tsx scripts/migrate.ts --import-furigana",
    "db:import:examples": "tsx scripts/migrate.ts --import-examples",
    "db:build": "tsx scripts/build-database.ts",
    "db:reset": "tsx scripts/migrate.ts --reset",
    "db:stats": "tsx scripts/migrate.ts --stats",
    "db:verify": "tsx scripts/migrate.ts --verify",
    "db:fetch": "tsx scripts/fetch-data.ts",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:search": "jest __tests__/search.test.ts --config jest.config.node.js --watchAll=false --verbose",
    "test:dictionary": "jest __tests__/dictionary.test.ts --config jest.config.node.js --watchAll=false --verbose",
    "test:history": "jest __tests__/history.test.ts --config jest.config.node.js --watchAll=false --verbose",
    "test:kanji": "jest __tests__/kanji.test.ts --config jest.config.node.js --watchAll=false --verbose",
    "test:utils": "jest __tests__/database-utils.test.ts --config jest.config.node.js --watchAll=false --verbose",
    "test:db": "jest __tests__ --config jest.config.node.js --watchAll=false --verbose",
    "test:ci": "jest --watchAll=false --verbose",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "deploy": "tsx pages/deploy-pages.ts",
    "deploy:production": "tsx pages/deploy-pages.ts --production"
  },
  "jest": {
    "preset": "jest-expo"
  },
